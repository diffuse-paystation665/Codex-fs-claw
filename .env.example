FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_SEND_MAX_RETRIES=3
FEISHU_SEND_RETRY_BASE_MS=400

# Use your own Feishu open_id in public or team usage.
# Only use * for local debugging.
ALLOWED_OPEN_IDS=ou_xxx

# Keep this as small as practical in safe mode.
WORKSPACE_ROOTS=C:\your-workspace\CodexClaw

CODEX_AUTH_MODE=chatgpt
CODEX_SESSION_MODE=operator

# Safe default for public release: approval-gated workspace mode.
# Set to computer only if you explicitly want full local-computer control.
CODEX_CONTROL_SCOPE=workspace

CODEX_MODEL=
CODEX_BIN=
DATA_DIR=./data
LOG_DIR=./logs
LOG_LEVEL=info
APPROVAL_TTL_MINUTES=30
CRON_POLL_INTERVAL_MS=30000
CRON_DEFAULT_MAX_RETRIES=2
CRON_RETRY_BASE_MINUTES=5
