{
  "name": "codex-claw",
  "version": "0.1.0",
  "private": false,
  "description": "Put official Codex into Feishu private chat with safe defaults, approval-gated local control, cron jobs, and skill management.",
  "license": "MIT",
  "homepage": "https://github.com/R2Phil-hub/Codex-fs-claw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R2Phil-hub/Codex-fs-claw.git"
  },
  "bugs": {
    "url": "https://github.com/R2Phil-hub/Codex-fs-claw/issues"
  },
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "assistant",
    "approval",
    "local-first",
    "cron",
    "skills",
    "automation"
  ],
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "bridge:restart": "powershell -ExecutionPolicy Bypass -File scripts/restart-bridge.ps1",
    "github:check": "powershell -ExecutionPolicy Bypass -File scripts/github-check.ps1",
    "github:publish": "powershell -ExecutionPolicy Bypass -File scripts/publish-github.ps1",
    "test": "tsx --test src/**/*.test.ts",
    "codex:help": "codex --help",
    "codex:app-server:help": "codex app-server --help"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@openai/codex": "^0.114.0",
    "dotenv": "^17.2.3",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
